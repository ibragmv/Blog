{
  "name": "@archive/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./admin-auth-shared": {
      "types": "./src/admin-auth-shared.ts",
      "default": "./src/admin-auth-shared.ts"
    },
    "./content": {
      "types": "./src/content.ts",
      "default": "./src/content.ts"
    },
    "./dates": {
      "types": "./src/dates.ts",
      "default": "./src/dates.ts"
    },
    "./normalize-next-path": {
      "types": "./src/normalize-next-path.ts",
      "default": "./src/normalize-next-path.ts"
    },
    "./site": {
      "types": "./src/site.ts",
      "default": "./src/site.ts"
    },
    "./translation": {
      "types": "./src/translation.ts",
      "default": "./src/translation.ts"
    },
    "./utils": {
      "types": "./src/utils.ts",
      "default": "./src/utils.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome check src package.json tsconfig.json tsconfig.build.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  }
}
