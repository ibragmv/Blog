{
  "framework": "vite",
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "bunVersion": "1.2.21",
  "rewrites": [
    {
      "source": "/feed.xml",
      "destination": "/api/feed"
    },
    {
      "source": "/blog/:slug",
      "destination": "/api/post-html?slug=:slug"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
