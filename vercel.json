{
  "rewrites": [
    {
      "source": "/feed.xml",
      "destination": "/api/feed"
    },
    {
      "source": "/blog/:slug",
      "destination": "/api/post-html"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
