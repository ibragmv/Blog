{
  "name": "blog",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.2.21",
  "engines": {
    "bun": ">=1.2.21"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "clean": "rm -rf .next .turbo .vercel tsconfig.tsbuildinfo",
    "typecheck": "bun scripts/typecheck.mjs",
    "lint": "biome check .",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "analyze": "next build --turbopack --experimental-analyze",
    "check": "turbo run lint typecheck build --continue --ui=stream",
    "convex": "bun scripts/convex-dev.mjs",
    "deploy": "convex deploy --typecheck=disable"
  },
  "trustedDependencies": [
    "protobufjs"
  ],
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "katex": "^0.16.33",
    "lucide-react": "^0.546.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^22.14.0",
    "tailwindcss": "^4.1.14",
    "turbo": "^2.8.13",
    "typescript": "~5.8.2"
  }
}
