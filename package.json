{
  "name": "archive",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.2.21"
  },
  "scripts": {
    "dev": "bun scripts/turbo-task.mjs dev",
    "build": "bun scripts/turbo-task.mjs build",
    "release": "bun run build",
    "start": "bun scripts/turbo-task.mjs start",
    "typecheck": "bun scripts/turbo-task.mjs typecheck",
    "typecheck:affected": "bunx turbo run typecheck --affected --ui=stream",
    "typecheck:core": "bunx turbo run typecheck --filter=@archive/core --ui=stream",
    "lint": "bun scripts/turbo-task.mjs lint",
    "lint:affected": "bunx turbo run lint --affected --ui=stream",
    "lint:core": "bunx turbo run lint --filter=@archive/core --ui=stream",
    "convex": "eslint convex --max-warnings=0",
    "verify": "bunx turbo run lint typecheck build --continue --ui=stream",
    "verify:affected": "bunx turbo run lint typecheck build --affected --continue --ui=stream",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "bun scripts/turbo-task.mjs clean",
    "build:affected": "bunx turbo run build --affected --ui=stream",
    "build:core": "bunx turbo run build --filter=@archive/core --ui=stream",
    "devtools": "bunx turbo devtools",
    "graph:build": "bunx turbo run build --filter=// --graph",
    "ls:affected": "bunx turbo ls --affected",
    "deploy": "bun run verify && bunx convex deploy"
  },
  "trustedDependencies": [
    "protobufjs"
  ],
  "dependencies": {
    "@archive/core": "workspace:*",
    "@google/genai": "^1.43.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.33",
    "lucide-react": "^0.546.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@convex-dev/eslint-plugin": "^0.0.1-alpha.4",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.37.0",
    "tailwindcss": "^4.1.14",
    "turbo": "2.9.5",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.46.0"
  }
}
