{
  "name": "archive",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "bun": ">=1.2.21"
  },
  "scripts": {
    "dev": "bunx turbo run dev --filter=@archive/web --ui=stream",
    "build": "bunx turbo run build --filter=@archive/web --ui=stream",
    "release": "bun run build",
    "start": "bunx turbo run start --filter=@archive/web --ui=stream",
    "convex:codegen": "bun scripts/convex-codegen.mjs",
    "typecheck": "bun scripts/turbo-task.mjs typecheck",
    "typecheck:affected": "bunx turbo run typecheck --affected --ui=stream",
    "typecheck:web": "bunx turbo run typecheck --filter=@archive/web --ui=stream",
    "lint": "bun scripts/turbo-task.mjs lint",
    "lint:affected": "bunx turbo run lint --affected --ui=stream",
    "lint:web": "bunx turbo run lint --filter=@archive/web --ui=stream",
    "convex": "eslint convex --max-warnings=0",
    "verify": "bunx turbo run lint typecheck build --continue --ui=stream",
    "verify:affected": "bunx turbo run lint typecheck build --affected --continue --ui=stream",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "bun scripts/turbo-task.mjs clean",
    "build:affected": "bunx turbo run build --affected --ui=stream",
    "build:web": "bunx turbo run build --filter=@archive/web --ui=stream",
    "devtools": "bunx turbo devtools",
    "graph:build": "bunx turbo run build --graph",
    "ls:affected": "bunx turbo ls --affected",
    "deploy": "bun run verify && bun scripts/convex-deploy.mjs"
  },
  "trustedDependencies": [
    "protobufjs"
  ],
  "dependencies": {
    "convex": "^1.34.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@convex-dev/eslint-plugin": "^0.0.1-alpha.4",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.37.0",
    "tailwindcss": "^4.1.14",
    "turbo": "2.9.5",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.46.0"
  }
}
