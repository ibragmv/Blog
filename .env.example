# Convex
# CONVEX_DEPLOYMENT is for Convex CLI development commands.
CONVEX_DEPLOYMENT="dev:your-cloud-dev-deployment"
# VITE_CONVEX_URL is the Convex URL used by the app runtime.
VITE_CONVEX_URL="https://your-production-deployment.convex.cloud"

# Gemini API
GEMINI_API_KEY="your-gemini-api-key"

# Admin access
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"
