########################################
# Public site configuration
########################################
# Site URL used by metadata, OG, sitemap, and canonical links.
NEXT_PUBLIC_SITE_URL="https://your-domain.example"

########################################
# Convex configuration
########################################
# CONVEX_DEPLOYMENT is the production deployment used by Convex CLI commands.
CONVEX_DEPLOYMENT="prod:your-production-deployment"
# NEXT_PUBLIC_CONVEX_URL is the production Convex URL used by the app runtime.
NEXT_PUBLIC_CONVEX_URL="https://your-production-deployment.convex.cloud"

########################################
# Translation configuration
########################################
# GEMINI_API_KEY must exist only in the private .env file.
# GEMINI_MODEL is safe to publish and can be overridden if needed.
GEMINI_MODEL="gemini-2.5-flash"

########################################
# Admin access
########################################
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

########################################
# I hate deprecations
########################################
NODE_OPTIONS="--no-deprecation"
