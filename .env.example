########################################
# Public site configuration
########################################
# Site URL used by metadata, OG, sitemap, and canonical links.
NEXT_PUBLIC_SITE_URL="https://your-domain.example"

########################################
# Convex configuration
########################################
# CONVEX_DEPLOYMENT is for Convex CLI development commands.
CONVEX_DEPLOYMENT="dev:your-cloud-dev-deployment"
# NEXT_PUBLIC_CONVEX_URL is the Convex URL used by the app runtime.
NEXT_PUBLIC_CONVEX_URL="https://your-production-deployment.convex.cloud"

########################################
# Gemini API configuration
########################################
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="choose-your-model"

########################################
# Admin access
########################################
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

########################################
# I hate deprecations
########################################
NODE_OPTIONS="--no-deprecation"
