########################################
# Public site runtime
########################################
# Used for canonical URLs, metadata, OG images, and sitemap output.
NEXT_PUBLIC_SITE_URL="https://your-domain.example"

########################################
# Convex runtime
########################################
# Used by Convex CLI commands such as `convex deploy`.
CONVEX_DEPLOYMENT="prod:your-production-deployment"
# Public read runtime used by the Next.js app and public live sync.
NEXT_PUBLIC_CONVEX_URL="https://your-production-deployment.convex.cloud"

########################################
# Admin access
########################################
# Replace with private credentials in local `.env`.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

########################################
# Optional translation runtime
########################################
# Safe to commit. The private API key is intentionally omitted from this file
# and must live only in `.env` when translation is enabled.
GEMINI_MODEL="gemini-2.5-flash"

########################################
# Node runtime
########################################
NODE_OPTIONS="--no-deprecation"
