{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".env*",
    "biome.json",
    "bun.lock",
    "next.config.ts",
    "package.json",
    "postcss.config.mjs",
    "scripts/**",
    "tsconfig.json",
    "turbo.json",
    "vercel.json"
  ],
  "globalEnv": [
    "CI",
    "NODE_ENV",
    "GEMINI_MODEL",
    "NEXT_PUBLIC_CONVEX_URL",
    "NEXT_PUBLIC_SITE_URL"
  ],
  "globalPassThroughEnv": [
    "ADMIN_EMAIL",
    "ADMIN_PASSWORD",
    "CONVEX_DEPLOYMENT",
    "GEMINI_API_KEY"
  ],
  "tasks": {
    "//#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["CONVEX_DEPLOYMENT", "GEMINI_MODEL", "NEXT_PUBLIC_CONVEX_URL", "NEXT_PUBLIC_SITE_URL"]
    },
    "//#lint": {
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "//#typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "//#dev": {
      "cache": false,
      "persistent": true
    },
    "//#clean": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
