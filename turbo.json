{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    ".env.example",
    "biome.json",
    "bun.lock",
    "eslint.config.mjs",
    "next.config.ts",
    "package.json",
    "postcss.config.mjs",
    "tsconfig.json",
    "turbo.json",
    "vercel.json"
  ],
  "globalEnv": ["CI", "NODE_ENV"],
  "globalPassThroughEnv": [
    "ADMIN_EMAIL",
    "ADMIN_PASSWORD",
    "CONVEX_DEPLOYMENT",
    "GEMINI_API_KEY",
    "GEMINI_MODEL"
  ],
  "tasks": {
    "//#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["GEMINI_MODEL", "NEXT_PUBLIC_CONVEX_URL", "NEXT_PUBLIC_SITE_URL"]
    },
    "//#lint": {
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "//#typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$", "scripts/typecheck.mjs"],
      "outputs": [".next/types/**", ".next/dev/types/**"]
    },
    "//#dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "ADMIN_EMAIL",
        "ADMIN_PASSWORD",
        "CONVEX_DEPLOYMENT",
        "GEMINI_API_KEY",
        "GEMINI_MODEL",
        "NEXT_PUBLIC_CONVEX_URL",
        "NEXT_PUBLIC_SITE_URL"
      ]
    },
    "//#start": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "ADMIN_EMAIL",
        "ADMIN_PASSWORD",
        "CONVEX_DEPLOYMENT",
        "GEMINI_API_KEY",
        "GEMINI_MODEL",
        "NEXT_PUBLIC_CONVEX_URL",
        "NEXT_PUBLIC_SITE_URL"
      ]
    },
    "//#clean": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
