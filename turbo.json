{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".env*",
    "biome.json",
    "next.config.ts",
    "package.json",
    "postcss.config.mjs",
    "tsconfig.json",
    "turbo.json"
  ],
  "globalEnv": ["CI", "NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "convex/**",
        "next-env.d.ts",
        "next.config.ts",
        "package.json",
        "postcss.config.mjs",
        "public/**",
        "src/**",
        "tsconfig.json"
      ],
      "outputs": [".next/**"],
      "env": ["CONVEX_DEPLOYMENT", "NEXT_PUBLIC_CONVEX_URL"]
    },
    "analyze": {
      "dependsOn": ["build"],
      "inputs": [".next/**", "package.json", "scripts/**", "src/**"],
      "outputs": [".next/**"],
      "env": ["CONVEX_DEPLOYMENT", "NEXT_PUBLIC_CONVEX_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["biome.json", "next.config.ts", "package.json", "src/**", "tsconfig.json"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["next-env.d.ts", "next.config.ts", "package.json", "src/**", "tsconfig.json"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
