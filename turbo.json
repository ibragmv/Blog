{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    ".env.example",
    ".github/workflows/**",
    "biome.json",
    "bun.lock",
    "convex.json",
    "eslint.config.mjs",
    "package.json",
    "tsconfig.json",
    "turbo.json",
    "vercel.json"
  ],
  "globalEnv": ["CI", "NODE_ENV"],
  "globalPassThroughEnv": [
    "ADMIN_EMAIL",
    "ADMIN_PASSWORD",
    "CONVEX_DEPLOYMENT",
    "GEMINI_API_KEY",
    "GEMINI_MODEL"
  ],
  "tasks": {
    "//#lint": {
      "inputs": [
        ".env.example",
        ".github/**",
        ".gitignore",
        "README.md",
        "biome.json",
        "convex/**",
        "convex.json",
        "eslint.config.mjs",
        "package.json",
        "scripts/**",
        "turbo.json",
        "tsconfig.json",
        "vercel.json"
      ],
      "outputs": []
    },
    "//#typecheck": {
      "inputs": ["convex/**", "package.json", "scripts/typecheck-root.mjs", "tsconfig.json"],
      "outputs": []
    },
    "//#clean": {
      "cache": false
    },
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["GEMINI_MODEL", "NEXT_PUBLIC_CONVEX_URL", "NEXT_PUBLIC_SITE_URL"]
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": []
    },
    "typecheck": {
      "inputs": ["$TURBO_DEFAULT$", "scripts/typecheck.mjs"],
      "outputs": [".next/types/**", ".next/dev/types/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "ADMIN_EMAIL",
        "ADMIN_PASSWORD",
        "CONVEX_DEPLOYMENT",
        "GEMINI_API_KEY",
        "GEMINI_MODEL",
        "NEXT_PUBLIC_CONVEX_URL",
        "NEXT_PUBLIC_SITE_URL"
      ]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "ADMIN_EMAIL",
        "ADMIN_PASSWORD",
        "CONVEX_DEPLOYMENT",
        "GEMINI_API_KEY",
        "GEMINI_MODEL",
        "NEXT_PUBLIC_CONVEX_URL",
        "NEXT_PUBLIC_SITE_URL"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}
